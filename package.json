{
  "name": "obsidian-step-viewer",
  "version": "1.11.4",
  "description": "View STEP (.step/.stp) CAD models in a 3D viewer inside Obsidian.",
  "main": "main.js",
  "scripts": {
    "patch-occt": "node scripts/patch-occt-memory.mjs",
    "dev": "npm run patch-occt && node esbuild.config.mjs",
    "build": "npm run patch-occt && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "step",
    "cad",
    "3d",
    "occt",
    "three"
  ],
  "author": "Ondřej Uhnávy",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.160.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "occt-import-js": "0.0.23",
    "three": "^0.160.0"
  }
}
